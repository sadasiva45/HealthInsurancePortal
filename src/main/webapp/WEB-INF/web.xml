<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <!-- Session Timeout -->
    <session-config>
        <session-timeout>5</session-timeout>
    </session-config>

    <!-- Welcome File -->
    <welcome-file-list>
        <welcome-file>login.jsp</welcome-file>
    </welcome-file-list>

    <!-- Servlets -->

    <!-- View Claims Servlet -->
    <servlet>
        <servlet-name>ViewClaimsServlet</servlet-name>
        <servlet-class>com.healthsure.servlet.ViewClaimsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ViewClaimsServlet</servlet-name>
        <url-pattern>/viewClaims</url-pattern>
    </servlet-mapping>

    <!-- Update Claim Status Servlet -->
    <servlet>
        <servlet-name>UpdateClaimStatusServlet</servlet-name>
        <servlet-class>com.healthsure.servlet.UpdateClaimStatusServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UpdateClaimStatusServlet</servlet-name>
        <url-pattern>/updateClaimStatus</url-pattern>
    </servlet-mapping>

</web-app>
